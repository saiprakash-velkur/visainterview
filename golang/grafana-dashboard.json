{
  "dashboard": {
    "title": "Financial Transaction System",
    "panels": [
      {
        "title": "Active Goroutines",
        "targets": [
          {
            "expr": "go_goroutines"
          }
        ],
        "type": "graph"
      },
      {
        "title": "HTTP Request Rate",
        "targets": [
          {
            "expr": "rate(http_requests_total[5m])"
          }
        ],
        "type": "graph"
      },
      {
        "title": "HTTP Request Duration (p95)",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))"
          }
        ],
        "type": "graph"
      },
      {
        "title": "Transaction Rate by Type",
        "targets": [
          {
            "expr": "rate(transaction_total[5m])"
          }
        ],
        "type": "graph"
      },
      {
        "title": "Optimistic Lock Retries",
        "targets": [
          {
            "expr": "rate(optimistic_lock_retries_total[5m])"
          }
        ],
        "type": "graph"
      },
      {
        "title": "Memory Usage (MB)",
        "targets": [
          {
            "expr": "go_memstats_alloc_bytes / 1024 / 1024"
          }
        ],
        "type": "graph"
      },
      {
        "title": "GC Rate",
        "targets": [
          {
            "expr": "rate(go_gc_duration_seconds_count[5m])"
          }
        ],
        "type": "graph"
      }
    ]
  }
}
